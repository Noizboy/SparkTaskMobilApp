{
  "expo": {
    "name": "Spark Task",
    "slug": "sparktaskmobil",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#044728"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sparktask.mobile"
    },
    "android": {
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#044728"
      },
      "package": "com.sparktask.mobile",
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Spark Task to access your photos to upload job documentation.",
          "cameraPermission": "Allow Spark Task to use the camera for job photo documentation."
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#044728",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "481e8831-a782-4624-bb64-f5ee0542ec58"
      }
    }
  }
}